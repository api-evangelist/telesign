    "name": "Telesign SMS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Telesign SMS API enables sending SMS messages including alerts, notifications, reminders, marketing messages, and one-time passwords to phone numbers worldwide. Messages are classified by type (OTP, ARN, or MKT) and support delivery status tracking.\n\nContact Support:\n Name: Telesign Developer Support",
      "type": "text/plain"
    }
  }
