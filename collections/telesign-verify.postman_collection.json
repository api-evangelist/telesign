  "info": {
    "_postman_id": "0c282b3f-2aa0-41ca-a29e-ba6e6f562e93",
    "name": "Telesign Verify API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Telesign Verify API enables multi-channel phone-based verification and multi-factor authentication (MFA). Send one-time passcodes (OTPs) via SMS, voice, WhatsApp, Viber, RCS, or email, and verify the code the end user submits.\n\nContact Support:\n Name: Telesign Developer Support",
      "type": "text/plain"
    }
