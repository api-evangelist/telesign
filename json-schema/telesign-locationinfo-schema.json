{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/LocationInfo",
  "title": "LocationInfo",
  "type": "object",
  "properties": {
    "city": {
      "type": "string"
    },
    "county": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "zip": {
      "type": "string"
    },
    "country": {
      "type": "object",
      "properties": {
        "iso2": {
          "type": "string"
        },
        "iso3": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "time_zone": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "utc_offset_min": {
          "type": "string"
        },
        "utc_offset_max": {
          "type": "string"
        }
      }
    },
    "coordinates": {
      "type": "object",
      "properties": {
        "latitude": {
          "type": "string"
        },
        "longitude": {
          "type": "string"
        }
      }
    }
  }
}